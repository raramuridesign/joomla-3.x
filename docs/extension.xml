<?xml version="1.0" encoding="utf-8"?>
<!--
    Joomla 3.x (JoomlaWorks Security Distribution) — Update Details
    Hosted via GitHub Pages at https://joomlaworks.github.io/joomla-3.x/extension.xml
    Referenced as detailsurl by every <extension> entry in list.xml.

    This format mirrors update.joomla.org/core/extension.xml exactly.
    com_joomlaupdate fetches this URL to obtain the download link and version details
    once a matching update has been identified via list.xml.
-->
<updates>
    <update>
        <name>Joomla! 3.15</name>
        <description>Joomla! 3.15 CMS</description>
        <element>joomla</element>
        <type>file</type>
        <version>3.15.0</version>
        <infourl title="Joomla! 3.15.0 — Changelog">https://github.com/joomlaworks/joomla-3.x/blob/main/CHANGELOG.md</infourl>
        <downloads>
            <downloadurl type="full" format="zip">https://github.com/joomlaworks/joomla-3.x/releases/download/rolling/joomla-latest.zip</downloadurl>
        </downloads>
        <tags>
            <tag>stable</tag>
        </tags>
        <maintainer>JoomlaWorks</maintainer>
        <maintainerurl>https://github.com/joomlaworks/joomla-3.x</maintainerurl>
        <section>STS</section>
        <targetplatform name="joomla" version="3\.1[0-9]" />
        <php_minimum>7.1.0</php_minimum>
    </update>
</updates>

