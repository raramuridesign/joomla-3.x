<?xml version="1.0" encoding="utf-8"?>
<!--
    Joomla 3.x (JoomlaWorks Security Distribution) — Update Collection
    Hosted via GitHub Pages at https://joomlaworks.github.io/joomla-3.x/list.xml
    Consumed by com_joomlaupdate (type="collection" in #__update_sites).

    This format mirrors update.joomla.org/core/list.xml exactly.
    Each <extension> entry's targetplatformversion is matched (as a regexp) against JVERSION
    on the visitor's site. Matching entries cause their detailsurl to be fetched for the
    actual download URL and version comparison.

    To release a new version (e.g. 3.16.0):
      1. Bump version="3.15.0" → version="3.16.0" in every <extension> entry below.
      2. Add a new <extension> row for targetplatformversion="3.16" so sites already on 3.16
         can receive future updates.
      3. Update docs/extension.xml with the new version and release notes.
      4. Bump MINOR_VERSION / RELEASE / DEV_LEVEL in libraries/src/Version.php.
      5. Commit and push to main — the GitHub Action rebuilds joomla-latest.zip automatically.
-->
<extensionset name="Joomla Core" description="Joomla! Core">
    <extension name="Joomla" element="joomla" type="file" version="3.15.0" targetplatformversion="3.10" detailsurl="https://joomlaworks.github.io/joomla-3.x/extension.xml" />
    <extension name="Joomla" element="joomla" type="file" version="3.15.0" targetplatformversion="3.11" detailsurl="https://joomlaworks.github.io/joomla-3.x/extension.xml" />
    <extension name="Joomla" element="joomla" type="file" version="3.15.0" targetplatformversion="3.12" detailsurl="https://joomlaworks.github.io/joomla-3.x/extension.xml" />
    <extension name="Joomla" element="joomla" type="file" version="3.15.0" targetplatformversion="3.13" detailsurl="https://joomlaworks.github.io/joomla-3.x/extension.xml" />
    <extension name="Joomla" element="joomla" type="file" version="3.15.0" targetplatformversion="3.14" detailsurl="https://joomlaworks.github.io/joomla-3.x/extension.xml" />
    <extension name="Joomla" element="joomla" type="file" version="3.15.0" targetplatformversion="3.15" detailsurl="https://joomlaworks.github.io/joomla-3.x/extension.xml" />
</extensionset>

